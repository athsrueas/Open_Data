# New curators should create a local .env from this file.
# Never commit the filled .env file.

# Optional human reference copied from the "Your wallet" field in export-wallet UI.
GEO_WALLET=

# Required. The curator's own Geo private key from https://www.geobrowser.io/export-wallet
# Either raw hex or 0x-prefixed hex is fine in this starter.
GEO_PRIVATE_KEY=

# Optional but recommended after the first successful setup check.
# This is the curator's own personal space ID.
GEO_PERSONAL_SPACE_ID=

# Optional until the curator is working in a specific DAO or target space.
GEO_TARGET_SPACE_ID=
GEO_TARGET_SPACE_ADDRESS=
GEO_TARGET_SPACE_NAME=
GEO_TARGET_SPACE_PAGE_ID=
GEO_TARGET_SPACE_ENTITY_ID=
GEO_TARGET_PAGE_TYPE_ID=

# Defaults
GEO_NETWORK=TESTNET
DRY_RUN=1
